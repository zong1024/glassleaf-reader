{
  "name": "@glassleaf/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @glassleaf/contracts build && tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "pnpm --filter @glassleaf/contracts build && prisma generate && tsc -p tsconfig.json",
    "db:generate": "prisma generate",
    "db:push": "node scripts/prisma-db-push.mjs",
    "db:seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.3.0",
    "@glassleaf/contracts": "workspace:*",
    "@prisma/client": "^6.19.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.2.3",
    "fast-xml-parser": "^5.3.0",
    "fastify": "^5.6.1",
    "gray-matter": "^4.0.3",
    "mime-types": "^3.0.1",
    "pdf-lib": "^1.17.1",
    "unzipper": "^0.12.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^24.10.1",
    "@types/unzipper": "^0.10.11",
    "prisma": "^6.19.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
